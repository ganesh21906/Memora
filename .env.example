# ── Next.js Frontend ─────────────────────────────────────────────────────────
# URL of the running FastAPI backend (no trailing slash)
BACKEND_URL=http://localhost:8000

# ── FastAPI Backend (.env in project root) ───────────────────────────────────
# Get your Groq API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM model to use (default: llama-3.3-70b-versatile)
LLM_MODEL=llama-3.3-70b-versatile

# Set to true to use local sample data instead of live Gmail
USE_DEMO_MODE=true

# Gmail OAuth (only needed when USE_DEMO_MODE=false)
# Download credentials from Google Cloud Console → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
