# ── Next.js Frontend ─────────────────────────────────────────────────────────
# URL of the running FastAPI backend (no trailing slash)
BACKEND_URL=http://localhost:8000

# CopilotKit Runtime endpoint (used by CopilotChat)
NEXT_PUBLIC_COPILOT_RUNTIME_URL=/api/copilotkit

# Gemini key for CopilotKit runtime route in Next.js
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── FastAPI Backend (.env in project root) ───────────────────────────────────
# Use either LLM_API_KEY or GEMINI_API_KEY
LLM_API_KEY=your_gemini_or_openai_compatible_key_here

# Optional overrides for OpenAI-compatible endpoint and model
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# Set to true to use local sample data instead of live Gmail
USE_DEMO_MODE=true

# Gmail OAuth (only needed when USE_DEMO_MODE=false)
# Download credentials from Google Cloud Console → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
